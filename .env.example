# Sentinel Core — Environment Variables
# Copy this file to .env and fill in your values.
# All variables are prefixed with SENTINEL_

# ── LLM — GitHub Models (recommended, free with GitHub account) ───────────────
# Generate a PAT at: https://github.com/settings/tokens
# Required scopes: none (public GitHub Models access uses the token for identity)
SENTINEL_GITHUB_TOKEN=your_github_pat_here

# Model to use via GitHub Models (free tier):
#   gpt-4o          — OpenAI GPT-4o (best reasoning)
#   gpt-4o-mini     — faster + cheaper
#   Phi-4           — Microsoft Phi-4 (very capable, free)
SENTINEL_LLM_MODEL=gpt-4o

# ── LLM — Anthropic (alternative, requires paid account) ─────────────────────
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Logging ──────────────────────────────────────────────────────────────────
# Verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
SENTINEL_LOG_LEVEL=INFO

# Set to true in production/CI for machine-readable JSON logs
SENTINEL_JSON_LOGS=false

# ── Parsing ───────────────────────────────────────────────────────────────────
# Max source file size to analyse (KB)
SENTINEL_MAX_FILE_SIZE_KB=512

# ── FRONTEND / DEPLOYMENT ──────────────────────────────────────────────────────
# Used by Next.js Frontend to connect to Backend API.
# In development: leave blank (uses /api proxy)
# In production: set to your Backend URL
# Example: https://sentinel-core-backend.onrender.com
# Add to Vercel → Settings → Environment Variables as NEXT_PUBLIC_API_URL
NEXT_PUBLIC_API_URL=

# Max AST tree depth (prevents stack overflow on deeply nested code)
SENTINEL_MAX_AST_DEPTH=200

# ── Graph Builder ─────────────────────────────────────────────────────────────
# Hard cap on nodes per Code Property Graph
SENTINEL_MAX_GRAPH_NODES=50000

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Seconds before a sandboxed execution is killed
SENTINEL_SANDBOX_TIMEOUT=15

# Memory limit for sandboxed processes (MB)
SENTINEL_SANDBOX_MAX_MEMORY_MB=256

# ── Workspace ─────────────────────────────────────────────────────────────────
# Root directory Sentinel analyses (default: current dir)
SENTINEL_WORKSPACE_ROOT=.
